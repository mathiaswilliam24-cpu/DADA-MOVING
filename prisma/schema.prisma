generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  CUSTOMER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CHECKIN_COMPLETE
  ACTIVE
  DROPOFF_PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum FuelLevel {
  FULL
  THREE_QUARTER
  HALF
  QUARTER
  EMPTY
}

// ============================================================
// NEXTAUTH MODELS
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  bookings Booking[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CORE BUSINESS MODELS
// ============================================================

model Van {
  id            String   @id @default(cuid())
  name          String
  description   String?
  seats         Int      @default(2)
  cargoCapacity String
  imageUrl      String?
  isAvailable   Boolean  @default(true)
  features      String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings     Booking[]
  blockedDates BlockedDate[]
}

model Booking {
  id             String        @id @default(cuid())
  bookingNumber  String        @unique
  userId         String
  vanId          String
  startDate      DateTime
  endDate        DateTime
  hours          Float
  deliveryAddress String
  stateTaxCode   String        @default("TX")

  rentalFee    Float
  insuranceFee Float
  subtotal     Float
  taxRate      Float
  taxAmount    Float
  totalAmount  Float

  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  stripePaymentId String?
  licenseUrl      String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  van     Van      @relation(fields: [vanId], references: [id])
  receipt Receipt?
  checkIn CheckIn?
  dropOff DropOff?
  notifications NotificationLog[]
}

model CheckIn {
  id        String   @id @default(cuid())
  bookingId String   @unique

  // Photos obligatoires
  photoFront     String?
  photoRear      String?
  photoRight     String?
  photoLeft      String?
  photoInterior  String?
  photoDashboard String?
  photoFuelGauge String?
  photoDamages   String[] @default([])

  // Infos véhicule
  mileageStart Int
  fuelLevel    FuelLevel
  driverName   String

  // Signature électronique
  signatureData  String?
  termsAccepted  Boolean  @default(false)
  signedAt       DateTime?

  // Timestamps
  checkInTime DateTime @default(now())
  createdAt   DateTime @default(now())

  // Notifications
  smsSentAt    DateTime?
  emailSentAt  DateTime?
  smsStatus    String?
  emailStatus  String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model DropOff {
  id        String   @id @default(cuid())
  bookingId String   @unique

  // Médias
  videoUrl   String?
  photos     String[] @default([])

  // Infos véhicule
  mileageEnd    Int
  fuelLevelEnd  FuelLevel

  // GPS
  gpsLatitude  Float?
  gpsLongitude Float?
  gpsAddress   String?

  // Timestamps
  dropOffTime DateTime @default(now())
  createdAt   DateTime @default(now())

  // Notifications
  smsSentAt   DateTime?
  emailSentAt DateTime?
  smsStatus   String?
  emailStatus String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id        String   @id @default(cuid())
  bookingId String
  type      String
  status    String
  recipient String
  sentAt    DateTime @default(now())
  error     String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Receipt {
  id        String   @id @default(cuid())
  bookingId String   @unique
  pdfUrl    String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model BlockedDate {
  id     String   @id @default(cuid())
  vanId  String
  date   DateTime
  reason String?

  van Van @relation(fields: [vanId], references: [id], onDelete: Cascade)
}

model StateTax {
  id      String @id @default(cuid())
  state   String @unique
  name    String
  taxRate Float
}

model AppSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
